{
 "version": 2,
 "builds": [
  {
   "src": "api/app.py",
   "use": "@vercel/python"
  },
  {
   "src": "client/package.json",
   "use": "@vercel/static-build",
   "config": {
    "distDir": "client/build"
   }
  }
 ],
 "rewrites": [
  {
   "source": "/api/(.*)",
   "destination": "/api/app.py"
  },
  {
   "source": "/(.*)",
   "destination": "/client/build/index.html"
  }
 ]
}
